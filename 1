<!DOCTYPE html>

<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>TESI · Control de Calidad · Financiera Cualli</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600;700;800&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
* { margin:0; padding:0; box-sizing:border-box; }
body { font-family:'IBM Plex Sans',sans-serif; background:#f1f5f9; color:#1a202c; min-height:100vh; }

/* ══ HEADER ══ */
.site-header { background:#515151; padding:0 40px; height:60px; display:flex; align-items:center; justify-content:space-between; position:sticky; top:0; z-index:100; box-shadow:0 2px 12px rgba(0,0,0,0.18); }
.header-brand { display:flex; align-items:center; gap:14px; }
.header-sep   { width:1px; height:22px; background:rgba(255,255,255,0.25); }
.header-title { font-size:13px; font-weight:700; color:#fff; letter-spacing:0.8px; text-transform:uppercase; }
.header-right { display:flex; align-items:center; gap:14px; }
.badge-comite { background:#FDB913; color:#000; font-size:10px; font-weight:800; letter-spacing:1.2px; text-transform:uppercase; padding:4px 12px; border-radius:3px; }
.header-fecha { font-size:11px; color:rgba(255,255,255,0.55); font-family:‘Inter’,sans-serif; }

/* ══ WRAPPER ══ */
.main-wrap { max-width:900px; margin:32px auto; padding:0 20px 60px; }

/* ══ SELECTOR ══ */
.periodo-card { background:#fff; border-radius:12px; border:1px solid #e2e8f0; padding:18px 24px; margin-bottom:24px; box-shadow:0 1px 4px rgba(0,0,0,0.05); display:flex; align-items:center; gap:16px; flex-wrap:wrap; }
.periodo-label-txt { font-size:11px; font-weight:700; color:#64748b; text-transform:uppercase; letter-spacing:1.2px; display:flex; align-items:center; gap:7px; flex-shrink:0; }
.select-wrap { position:relative; flex-shrink:0; }
.select-wrap::after { content:‘▾’; position:absolute; right:10px; top:50%; transform:translateY(-50%); font-size:11px; color:#94a3b8; pointer-events:none; }
.periodo-select { appearance:none; background:#f8fafc; border:1px solid #e2e8f0; border-radius:8px; padding:9px 32px 9px 14px; font-size:13px; font-weight:700; color:#1a202c; cursor:pointer; font-family:‘IBM Plex Sans’,sans-serif; transition:all 0.15s; }
.periodo-select:hover { border-color:#FDB913; }
.periodo-select:focus { outline:none; border-color:#FDB913; box-shadow:0 0 0 3px rgba(253,185,19,0.15); }
.select-anio { min-width:90px; }
.select-mes  { min-width:150px; }
.btn-ver { background:#FDB913; color:#000; border:none; border-radius:8px; padding:9px 20px; font-size:13px; font-weight:800; cursor:pointer; font-family:‘IBM Plex Sans’,sans-serif; letter-spacing:0.3px; transition:all 0.15s; display:flex; align-items:center; gap:6px; flex-shrink:0; }
.btn-ver:hover { background:#e0a90f; transform:translateY(-1px); box-shadow:0 3px 10px rgba(253,185,19,0.35); }
.periodo-status { margin-left:auto; }
.status-chip { display:inline-flex; align-items:center; gap:5px; padding:4px 10px; border-radius:20px; font-size:11px; font-weight:600; }
.status-chip.cargado  { background:#f0fdf4; border:1px solid #86efac; color:#059669; }
.status-chip.cargando { background:#fffbeb; border:1px solid #fde68a; color:#b45309; }
.status-chip.vacio    { background:#f8fafc; border:1px solid #e2e8f0; color:#94a3b8; }
.dot-anim { width:6px; height:6px; border-radius:50%; background:currentColor; animation:blink 1s infinite; }
@keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.2} }

/* ══ REPORTE ══ */
.reporte-wrap { background:#fff; border-radius:12px; overflow:hidden; box-shadow:0 4px 24px rgba(0,0,0,0.08); border:1px solid #e2e8f0; opacity:0; transform:translateY(14px); transition:opacity 0.4s ease,transform 0.4s ease; }
.reporte-wrap.visible { opacity:1; transform:translateY(0); }

/* ══ SKELETON ══ */
.skeleton-wrap { padding:32px 40px; }
.skeleton-row  { display:grid; grid-template-columns:repeat(3,1fr); gap:14px; margin-bottom:24px; }
.skeleton-box  { height:90px; border-radius:10px; background:linear-gradient(90deg,#f1f5f9 25%,#e2e8f0 50%,#f1f5f9 75%); background-size:200% 100%; animation:shimmer 1.4s infinite; }
.skeleton-bar  { height:20px; border-radius:5px; background:linear-gradient(90deg,#f1f5f9 25%,#e2e8f0 50%,#f1f5f9 75%); background-size:200% 100%; animation:shimmer 1.4s infinite; margin-bottom:10px; }
.skeleton-bar.w80 { width:80%; } .skeleton-bar.w60 { width:60%; } .skeleton-bar.w40 { width:40%; }
@keyframes shimmer { 0%{background-position:200% 0} 100%{background-position:-200% 0} }

/* ══ HEADER REPORTE ══ */
.rep-header { background:linear-gradient(135deg,#515151 0%,#3a3a3a 100%); }
.rep-header-top { display:flex; align-items:center; justify-content:space-between; padding:22px 40px 18px; border-bottom:1px solid rgba(255,255,255,0.07); }
.rep-logo-area  { display:flex; align-items:center; gap:16px; }
.rep-logo-bg    { background:#fff; border-radius:8px; width:46px; height:46px; display:flex; align-items:center; justify-content:center; flex-shrink:0; padding:6px; }
.rep-logo-img   { max-height:28px; max-width:34px; display:block; object-fit:contain; }
.rep-header-titulo { font-size:17px; font-weight:800; color:#fff; letter-spacing:-0.3px; }
.rep-header-sub    { font-size:11px; color:rgba(255,255,255,0.5); font-weight:500; margin-top:3px; }
.rep-mes-chip { background:#FDB913; color:#000; font-size:13px; font-weight:800; padding:5px 14px; border-radius:4px; display:inline-block; }
.rep-anio     { font-size:11px; color:rgba(255,255,255,0.4); margin-top:5px; text-align:right; font-family:‘Inter’,sans-serif; }

/* ══ KPIs ══ */
.kpi-section { padding:28px 40px; background:#fafbfc; border-bottom:1px solid #e2e8f0; }
.kpi-row { display:grid; grid-template-columns:repeat(3,1fr); gap:14px; }
.kpi-box { background:#fff; border:1px solid #e2e8f0; border-radius:10px; padding:16px 18px; display:flex; align-items:center; gap:14px; transition:box-shadow 0.2s,transform 0.2s; }
.kpi-box:hover { box-shadow:0 4px 16px rgba(0,0,0,0.07); transform:translateY(-1px); }
.kpi-icon-wrap { width:48px; height:48px; border-radius:10px; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
.kpi-box.total .kpi-icon-wrap      { background:#fffbeb; }
.kpi-box.completos .kpi-icon-wrap  { background:#f0fdf4; }
.kpi-box.incidencias .kpi-icon-wrap{ background:#fef2f2; }
.kpi-icon-img { width:26px; height:26px; }
.kpi-num { font-size:34px; font-weight:800; line-height:1; letter-spacing:-1.5px; }
.kpi-box.total .kpi-num      { color:#FDB913; }
.kpi-box.completos .kpi-num  { color:#059669; }
.kpi-box.incidencias .kpi-num{ color:#dc2626; }
.kpi-label { font-size:12px; font-weight:600; color:#64748b; margin-top:3px; }
.kpi-pct   { font-size:11px; color:#94a3b8; margin-top:2px; font-family:‘Inter’,sans-serif; }

/* ══ SECCIÓN ══ */
.rep-section { padding:32px 40px; border-bottom:1px solid #f1f5f9; }
.rep-section:last-child { border-bottom:none; }
.sec-titulo { text-align:center; margin-bottom:24px; }
.sec-titulo h2 { font-size:20px; font-weight:800; color:#1a202c; letter-spacing:-0.4px; margin-bottom:5px; }
.sec-titulo p  { font-size:12px; color:#64748b; font-weight:500; }

/* ══ RUBROS ══ */
.rubros-grid { display:grid; grid-template-columns:repeat(5,1fr); gap:10px; }
.rubro-card { background:#fff; border:1px solid #e2e8f0; border-radius:10px; padding:14px 12px; text-align:center; cursor:pointer; transition:box-shadow 0.2s,transform 0.2s,border-color 0.15s; position:relative; overflow:hidden; user-select:none; }
.rubro-card:hover { box-shadow:0 4px 14px rgba(0,0,0,0.09); transform:translateY(-2px); }
.rubro-card.activo { border-color: currentColor; box-shadow:0 4px 16px rgba(0,0,0,0.1); }
.rubro-card::before { content:’’; position:absolute; top:0; left:0; right:0; height:3px; }
.rubro-card.normal::before     { background:#FDB913; }
.rubro-card.col0::before       { background:#64748b; }
.rubro-card.renovacion::before { background:#06b6d4; }
.rubro-card.reestruc::before   { background:#f97316; }
.rubro-card.ampliacion::before { background:#a855f7; }
.rubro-nombre  { font-size:10px; font-weight:700; color:#64748b; text-transform:uppercase; letter-spacing:0.8px; margin-bottom:10px; }
.rubro-total   { font-size:28px; font-weight:800; line-height:1; letter-spacing:-1px; margin-bottom:2px; }
.rubro-card.normal .rubro-total     { color:#FDB913; }
.rubro-card.col0 .rubro-total       { color:#64748b; }
.rubro-card.renovacion .rubro-total { color:#06b6d4; }
.rubro-card.reestruc .rubro-total   { color:#f97316; }
.rubro-card.ampliacion .rubro-total { color:#a855f7; }
.rubro-sub { font-size:10px; color:#94a3b8; font-weight:500; margin-bottom:8px; }
.rubro-inc-badge { display:inline-flex; align-items:center; gap:4px; background:#fef2f2; border:1px solid #fecaca; border-radius:4px; padding:3px 8px; font-size:10px; font-weight:700; color:#dc2626; }
.rubro-inc-badge.cero { background:#f0fdf4; border-color:#bbf7d0; color:#059669; }
.rubro-chevron { font-size:11px; color:#94a3b8; margin-top:6px; transition:transform 0.25s; display:block; }
.rubro-card.activo .rubro-chevron { transform:rotate(180deg); }

/* ══ RUBRO DETALLE ══ */
.rubro-detalle-wrap {
max-height: 0;
overflow: hidden;
transition: max-height 0.4s cubic-bezier(0.4,0,0.2,1);
margin-top: 0;
}
.rubro-detalle-wrap.open { max-height: 1200px; margin-top: 12px; }

.rubro-detalle-inner {
background: #fff;
border: 1px solid #e2e8f0;
border-radius: 10px;
overflow: hidden;
}

.rubro-detalle-header {
padding: 12px 18px;
display: flex;
align-items: center;
justify-content: space-between;
border-bottom: 1px solid #f1f5f9;
}

.rubro-detalle-titulo {
font-size: 12px;
font-weight: 700;
color: #64748b;
text-transform: uppercase;
letter-spacing: 0.8px;
}

/* ══ DISTRIBUCIÓN ══ */
.tbl { width:100%; border-collapse:collapse; border:1px solid #e2e8f0; border-radius:6px; overflow:hidden; font-family:‘Inter’,sans-serif; }
.tbl th { background:#f8fafc; padding:11px 18px; text-align:left; font-size:10px; text-transform:uppercase; letter-spacing:1px; font-weight:700; color:#4a5568; border-bottom:2px solid #cbd5e1; }
.tbl td { padding:12px 18px; font-size:13px; border-bottom:1px solid #f1f5f9; vertical-align:middle; }
.tbl tr:last-child td { border-bottom:none; }
.tbl tr:nth-child(even) td { background:#f8fafc; }
.tbl tbody tr { animation:rowIn 0.22s ease both; }
@keyframes rowIn { from{opacity:0;transform:translateX(-6px);} to{opacity:1;transform:translateX(0);} }

/* Fila de total en tabla distribución */
.tbl tfoot tr td {
background: #f8fafc;
font-weight: 700;
font-size: 12px;
color: #1a202c;
border-top: 2px solid #e2e8f0;
padding: 10px 18px;
}

/* ══ TIPO BADGE ══ */
.tipo-badge { display:inline-block; padding:2px 8px; border-radius:4px; font-size:10px; font-weight:700; letter-spacing:0.3px; text-transform:uppercase; }
.tipo-normal     { background:#fffbeb; color:#b45309; border:1px solid #fde68a; }
.tipo-col0       { background:#f8fafc; color:#475569; border:1px solid #cbd5e1; }
.tipo-renovacion { background:#ecfeff; color:#0e7490; border:1px solid #a5f3fc; }
.tipo-reestruc   { background:#fff7ed; color:#c2410c; border:1px solid #fed7aa; }
.tipo-ampliacion { background:#faf5ff; color:#7c3aed; border:1px solid #ddd6fe; }

/* ══ INC BADGE ══ */
.inc-badge { display:inline-flex; align-items:center; justify-content:center; border:2px solid; border-radius:5px; padding:3px 11px; font-size:14px; font-weight:800; min-width:36px; }

/* ══ PROP BAR ══ */
.prop-bar-bg { background:#f1f5f9; border-radius:3px; height:4px; margin-top:6px; overflow:hidden; }
.prop-bar { height:100%; border-radius:3px; transition:width 0.9s cubic-bezier(0.4,0,0.2,1); }

/* ══ ÁREA ACORDEÓN ══ */
.area-header-row { display:flex; align-items:center; gap:12px; padding:14px 18px; border-radius:8px; border:1px solid; cursor:pointer; transition:filter 0.15s,box-shadow 0.15s; margin-bottom:8px; user-select:none; }
.area-header-row:hover { filter:brightness(0.97); box-shadow:0 2px 8px rgba(0,0,0,0.06); }
.area-icon    { width:38px; height:38px; }
.area-nombre  { font-size:15px; font-weight:700; color:#1a202c; }
.area-subtext { font-size:11px; color:#718096; font-weight:600; margin-top:2px; }
.area-chevron { margin-left:auto; font-size:18px; color:#94a3b8; transition:transform 0.3s; }
.area-header-row.open .area-chevron { transform:rotate(180deg); }
.area-badge-num { width:46px; height:46px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:17px; font-weight:900; color:#fff; flex-shrink:0; text-shadow:0 1px 2px rgba(0,0,0,0.12); }
.area-ok        { padding:14px 18px; border-radius:8px; background:#f0fdf4; border:1px solid #86efac; display:flex; align-items:center; gap:12px; margin-bottom:8px; }
.area-ok-nombre { font-size:15px; font-weight:700; color:#1a202c; }
.area-ok-sub    { font-size:13px; color:#047857; font-weight:600; margin-top:1px; }
.area-detail-table { max-height:0; overflow:hidden; transition:max-height 0.4s cubic-bezier(0.4,0,0.2,1); margin-bottom:8px; }
.area-detail-table.open { max-height:3000px; }

/* ══ TABLA DOCUMENTOS ══ */
.docs-table { width:100%; border-collapse:collapse; font-family:‘Inter’,sans-serif; }
.docs-table th { background:linear-gradient(135deg,#1e293b 0%,#334155 100%); padding:14px 16px; font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:1px; color:#e2e8f0; text-align:left; }
.docs-table th:first-child { width:40px; text-align:center; }
.docs-table td { padding:13px 16px; font-size:12px; border-bottom:1px solid #f1f5f9; vertical-align:top; }
.docs-table tr:nth-child(even) td { background:#f8fafc; }
.docs-table tr:last-child td { border-bottom:none; }
.docs-table tr:hover td { background:#fffbeb; }

.doc-num-circle {
width: 26px; height: 26px;
background: linear-gradient(135deg,#3b82f6,#2563eb);
border-radius: 50%;
display: inline-flex;
align-items: center;
justify-content: center;
font-size: 11px;
font-weight: 700;
color: #fff;
box-shadow: 0 2px 4px rgba(59,130,246,0.3);
}

.area-doc-badge {
display: inline-block;
border-radius: 5px;
padding: 2px 9px;
font-size: 11px;
font-weight: 700;
border: 1px solid;
}

/* ══ CIERRE ══ */
.cierre-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:14px; }
.cierre-card { background:#fff; border:1px solid #e2e8f0; border-radius:10px; padding:18px 16px; display:flex; align-items:center; gap:14px; transition:box-shadow 0.2s,transform 0.2s; }
.cierre-card:hover { box-shadow:0 4px 16px rgba(0,0,0,0.07); transform:translateY(-1px); }
.cierre-icon { width:44px; height:44px; border-radius:10px; display:flex; align-items:center; justify-content:center; font-size:20px; flex-shrink:0; }
.cierre-card.e1 .cierre-icon { background:#eff6ff; }
.cierre-card.e2 .cierre-icon { background:#fef3c7; }
.cierre-card.ef .cierre-icon { background:#f0fdf4; }
.cierre-num   { font-size:30px; font-weight:800; line-height:1; letter-spacing:-1px; }
.cierre-card.e1 .cierre-num { color:#3b82f6; }
.cierre-card.e2 .cierre-num { color:#f59e0b; }
.cierre-card.ef .cierre-num { color:#059669; }
.cierre-label { font-size:12px; font-weight:600; color:#64748b; margin-top:3px; }
.cierre-sub   { font-size:10px; color:#94a3b8; margin-top:2px; font-family:‘Inter’,sans-serif; }

/* ══ SORT ══ */
.tbl-controls { display:flex; align-items:flex-end; justify-content:space-between; margin-bottom:12px; gap:12px; }
.sort-sel { background:#f8fafc; border:1px solid #e2e8f0; border-radius:5px; padding:5px 10px; font-size:11px; font-weight:700; color:#515151; cursor:pointer; font-family:‘Inter’,sans-serif; }

/* ══ EMPTY ══ */
.empty-rep { text-align:center; padding:60px 20px; color:#94a3b8; }
.empty-rep-icon { font-size:40px; margin-bottom:12px; }
.empty-rep-text { font-size:15px; font-weight:500; }

/* ══ ANIMACIONES ══ */
@keyframes fadeSlide { from{opacity:0;transform:translateY(10px);} to{opacity:1;transform:translateY(0);} }
.rep-section { animation:fadeSlide 0.3s ease both; }
.rep-section:nth-child(2){ animation-delay:0.04s; }
.rep-section:nth-child(3){ animation-delay:0.08s; }
.rep-section:nth-child(4){ animation-delay:0.12s; }
.rep-section:nth-child(5){ animation-delay:0.16s; }
.rep-section:nth-child(6){ animation-delay:0.20s; }
@keyframes numPop { from{opacity:0;transform:scale(0.82);} to{opacity:1;transform:scale(1);} }
.num-pop { animation:numPop 0.4s cubic-bezier(0.34,1.56,0.64,1) both; }

/* ══ PANEL DETALLE ══ */
.overlay     { position:fixed; inset:0; background:rgba(0,0,0,0.32); z-index:300; display:none; backdrop-filter:blur(2px); }
.overlay.open{ display:block; }
.slide-panel { position:fixed; right:-520px; top:0; bottom:0; width:460px; background:#fff; z-index:400; box-shadow:-8px 0 40px rgba(0,0,0,0.15); transition:right 0.35s cubic-bezier(0.4,0,0.2,1); overflow-y:auto; border-left:4px solid #FDB913; }
.slide-panel.open { right:0; }
.sp-header   { background:#515151; padding:22px 26px 18px; position:relative; }
.sp-close    { position:absolute; top:14px; right:14px; width:30px; height:30px; background:rgba(255,255,255,0.1); border:1px solid rgba(255,255,255,0.2); border-radius:5px; color:#fff; font-size:18px; cursor:pointer; display:flex; align-items:center; justify-content:center; }
.sp-close:hover { background:rgba(255,255,255,0.2); }
.sp-id    { font-size:19px; font-weight:800; color:#fff; padding-right:36px; margin-bottom:3px; }
.sp-fecha { font-size:12px; color:rgba(255,255,255,0.5); font-family:‘Inter’,sans-serif; }
.sp-body  { padding:22px 26px; }
.sp-kpi-row { display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-bottom:22px; }
.sp-kpi { background:#f8fafc; border:1px solid #e2e8f0; border-radius:8px; padding:14px 16px; }
.sp-kpi-label { font-size:10px; font-weight:700; color:#94a3b8; text-transform:uppercase; letter-spacing:1px; margin-bottom:6px; }
.sp-kpi-val   { font-size:30px; font-weight:800; color:#dc2626; letter-spacing:-1px; line-height:1; }
.sp-sec-label { font-size:10px; font-weight:700; color:#94a3b8; text-transform:uppercase; letter-spacing:1.2px; margin-bottom:12px; padding-bottom:8px; border-bottom:1px solid #f1f5f9; }
.sp-area-row  { display:flex; align-items:center; justify-content:space-between; padding:11px 0; border-bottom:1px solid #f8fafc; }
.sp-area-row:last-child { border-bottom:none; }
.sp-area-left { display:flex; align-items:center; gap:10px; }
.sp-area-dot  { width:10px; height:10px; border-radius:2px; flex-shrink:0; }
.sp-area-name { font-size:14px; font-weight:600; color:#1a202c; }
.sp-area-pct  { font-size:11px; color:#94a3b8; margin-top:1px; font-family:‘Inter’,sans-serif; }
.sp-area-num  { font-size:22px; font-weight:800; }
</style>

</head>
<body>

<header class="site-header">
  <div class="header-brand">
    <img src="https://cualli.mx/wp-content/uploads/2022/07/cualli-bl@3x.png" alt="Cualli" style="height:28px;display:block;"
         onerror="this.style.display='none';document.getElementById('logoFallback').style.display='flex'">
    <div id="logoFallback" style="display:none;background:#FDB913;border-radius:4px;padding:3px 10px;font-weight:800;font-size:13px;color:#000;">CUALLI</div>
    <div class="header-sep"></div>
    <div class="header-title">Control de Calidad · TESI</div>
  </div>
  <div class="header-right">
    <div class="badge-comite">📊 Sesión Comité</div>
    <div class="header-fecha" id="fechaHoy"></div>
  </div>
</header>

<div class="main-wrap">

  <div class="periodo-card">
    <div class="periodo-label-txt">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#64748b" stroke-width="2.5"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
      Período
    </div>
    <div class="select-wrap">
      <select class="periodo-select select-anio" id="selectAnio" onchange="onCambioAnio()">
        <option value="2026">2026</option>
        <option value="2025">2025</option>
        <option value="2024">2024</option>
      </select>
    </div>
    <div class="select-wrap">
      <select class="periodo-select select-mes" id="selectMes">
        <option value="">— Mes —</option>
      </select>
    </div>
    <button class="btn-ver" onclick="verReporte()">Ver reporte →</button>
    <div class="periodo-status">
      <div class="status-chip vacio" id="statusChip"><span>Sin selección</span></div>
    </div>
  </div>

  <div class="reporte-wrap" id="repWrap">
    <div id="repContenido">
      <div class="empty-rep">
        <div class="empty-rep-icon">📅</div>
        <div class="empty-rep-text">Selecciona año y mes para ver el reporte</div>
      </div>
    </div>
  </div>

</div>

<div class="overlay" id="overlay" onclick="cerrarPanel()"></div>
<div class="slide-panel" id="slidePanel">
  <div class="sp-header">
    <button class="sp-close" onclick="cerrarPanel()">×</button>
    <div class="sp-id" id="spId">—</div>
    <div class="sp-fecha" id="spFecha">—</div>
  </div>
  <div class="sp-body">
    <div class="sp-kpi-row">
      <div class="sp-kpi"><div class="sp-kpi-label">Total Incidencias</div><div class="sp-kpi-val" id="spTotal">—</div></div>
      <div class="sp-kpi"><div class="sp-kpi-label">Áreas afectadas</div><div class="sp-kpi-val" style="color:#FDB913" id="spAreas">—</div></div>
    </div>
    <div class="sp-sec-label">Desglose por área</div>
    <div id="spAreasList"></div>
  </div>
</div>

<script>
// ════════════════════════════════════
// CONFIG
// ════════════════════════════════════
const AREAS_CFG = {
  'Comercial': { color:'#f97316', colorClaro:'#fb923c', colorOscuro:'#ea580c', colorBg:'#fff7ed', colorBorder:'#fed7aa', icono:'https://cdn-icons-png.freepik.com/512/14598/14598062.png' },
  'Cartera':   { color:'#ec4899', colorClaro:'#f472b6', colorOscuro:'#db2777', colorBg:'#fdf2f8', colorBorder:'#fbcfe8', icono:'https://cdn-icons-png.freepik.com/512/8376/8376410.png' },
  'Crédito':   { color:'#06b6d4', colorClaro:'#22d3ee', colorOscuro:'#0891b2', colorBg:'#ecfeff', colorBorder:'#a5f3fc', icono:'https://cdn-icons-png.freepik.com/512/1674/1674640.png' },
  'Jurídico':  { color:'#84cc16', colorClaro:'#C7FF6C', colorOscuro:'#0DA31A', colorBg:'#f7fee7', colorBorder:'#d9f99d', icono:'https://cdn-icons-png.freepik.com/512/4252/4252349.png' },
  'PLD':       { color:'#a855f7', colorClaro:'#D3A7FF', colorOscuro:'#9333ea', colorBg:'#faf5ff', colorBorder:'#e9d5ff', icono:'https://cdn-icons-png.freepik.com/512/3359/3359520.png' }
};

const ICONOS_KPI = {
  total:       'https://cdn-icons-png.freepik.com/512/4371/4371079.png',
  completos:   'https://cdn-icons-png.freepik.com/512/2724/2724742.png',
  incidencias: 'https://cdn-icons-png.freepik.com/512/7100/7100197.png'
};

const RUBROS_CFG = {
  'Normal':       { cls:'normal',     label:'Normal / Originación', emoji:'🏠' },
  'Colocación 0': { cls:'col0',       label:'Colocación 0',         emoji:'🔵' },
  'Renovación':   { cls:'renovacion', label:'Renovación',           emoji:'🔄' },
  'Reestructura': { cls:'reestruc',   label:'Reestructura',         emoji:'🔧' },
  'Ampliación':   { cls:'ampliacion', label:'Ampliación',           emoji:'📈' }
};

const COLORES_AREA = {
  'Comercial': { bg:'#fff7ed', border:'#fed7aa', texto:'#c2410c' },
  'Cartera':   { bg:'#fdf2f8', border:'#fbcfe8', texto:'#be185d' },
  'Crédito':   { bg:'#ecfeff', border:'#a5f3fc', texto:'#0e7490' },
  'Jurídico':  { bg:'#f7fee7', border:'#d9f99d', texto:'#3f6212' },
  'PLD':       { bg:'#faf5ff', border:'#e9d5ff', texto:'#7c3aed' }
};

const MESES_L = ['','Enero','Febrero','Marzo','Abril','Mayo','Junio','Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'];

// ════════════════════════════════════
// ESTADO
// ════════════════════════════════════
const CACHE    = {};
const CARGANDO = {};
let anioActual    = 2026;
let datosMostrados = null;
let rubroAbierto   = null;

// ════════════════════════════════════
// INIT
// ════════════════════════════════════
document.addEventListener('DOMContentLoaded', () => {
  const hoy = new Date();
  document.getElementById('fechaHoy').textContent =
    hoy.toLocaleDateString('es-MX',{weekday:'long',day:'numeric',month:'long',year:'numeric'});

  document.getElementById('repContenido').innerHTML = `
    <div class="empty-rep"><div class="empty-rep-icon">⏳</div><div class="empty-rep-text">Cargando datos de 2026...</div></div>`;

  cargarAnio(2026, () => {
    poblarMeses(2026);
    const mc    = hoy.getMonth() + 1;
    const clave = `2026-${String(mc).padStart(2,'0')}`;
    if (CACHE[2026] && CACHE[2026][clave]) {
      document.getElementById('selectMes').value = String(mc);
      verReporte();
    } else {
      document.getElementById('repContenido').innerHTML =
        `<div class="empty-rep"><div class="empty-rep-icon">📅</div><div class="empty-rep-text">Selecciona año y mes para ver el reporte</div></div>`;
    }
  });
});

// ════════════════════════════════════
// CARGA POR AÑO
// ════════════════════════════════════
function cargarAnio(anio, cb) {
  anio = parseInt(anio);
  if (CACHE[anio])    { if (cb) cb(); return; }
  if (CARGANDO[anio]) return;
  CARGANDO[anio] = true;
  setStatus('cargando', `Cargando ${anio}...`);

  google.script.run
    .withSuccessHandler(datos => {
      CACHE[anio]    = datos || {};
      CARGANDO[anio] = false;
      setStatus('cargado', `${anio} listo`);
      if (cb) cb();
    })
    .withFailureHandler(err => {
      CARGANDO[anio] = false;
      console.error('Error:', err);
      setStatus('vacio', 'Error al cargar');
    })
    .getDatosTESIAnio(anio);
}

function onCambioAnio() {
  const anio = parseInt(document.getElementById('selectAnio').value);
  anioActual = anio;
  document.getElementById('selectMes').innerHTML = '<option value="">— Cargando... —</option>';
  cargarAnio(anio, () => poblarMeses(anio));
}

function poblarMeses(anio) {
  const sel  = document.getElementById('selectMes');
  const data = CACHE[anio] || {};
  const disp = Object.keys(data)
    .filter(k => k.startsWith(String(anio)))
    .map(k => parseInt(k.split('-')[1]))
    .sort((a,b) => a-b);

  sel.innerHTML = '<option value="">— Mes —</option>';
  disp.forEach(m => {
    const o = document.createElement('option');
    o.value = String(m);
    o.textContent = MESES_L[m];
    sel.appendChild(o);
  });

  setStatus(disp.length ? 'cargado' : 'vacio',
    disp.length ? `${disp.length} mes${disp.length!==1?'es':''} disponible${disp.length!==1?'s':''}` : `Sin datos ${anio}`);
}

function verReporte() {
  const anio = parseInt(document.getElementById('selectAnio').value);
  const mes  = parseInt(document.getElementById('selectMes').value);
  if (!mes) { setStatus('vacio','Selecciona un mes'); return; }
  const clave = `${anio}-${String(mes).padStart(2,'0')}`;
  const datos = CACHE[anio] && CACHE[anio][clave];
  if (!datos) { setStatus('vacio','Sin datos para este período'); return; }
  datosMostrados = datos;
  rubroAbierto   = null;
  renderReporte(datos, MESES_L[mes], anio);
  setStatus('cargado', `${MESES_L[mes]} ${anio}`);
}

function setStatus(tipo, texto) {
  const chip = document.getElementById('statusChip');
  chip.className = `status-chip ${tipo}`;
  chip.innerHTML = tipo==='cargando'
    ? `<div class="dot-anim"></div><span>${texto}</span>`
    : `<span>${texto}</span>`;
}

// ════════════════════════════════════
// RENDER PRINCIPAL
// ════════════════════════════════════
function renderReporte(datos, nombreMes, anio) {
  const wrap = document.getElementById('repWrap');
  const cont = document.getElementById('repContenido');

  cont.innerHTML = htmlSkeleton();
  wrap.classList.remove('visible');
  requestAnimationFrame(() => wrap.classList.add('visible'));

  const pctC     = datos.total ? Math.round((datos.sinIncidencias/datos.total)*100) : 0;
  const pctI     = datos.total ? Math.round((datos.conIncidencias/datos.total)*100) : 0;
  const totArea  = totalesPorArea(datos.incidencias||[]);
  const totalIncs= Object.values(totArea).reduce((s,v)=>s+v,0);

  requestAnimationFrame(() => {
    cont.innerHTML =
      htmlHeader(nombreMes.toUpperCase(), `${nombreMes} ${anio}`) +
      htmlKPIs(datos.total, datos.sinIncidencias, datos.conIncidencias, pctC, pctI) +
      htmlRubros(datos.conteoPorTipo, datos.incidencias||[], `${nombreMes} ${anio}`) +
      htmlDistribucion(totArea, totalIncs, `${nombreMes} ${anio}`) +
      htmlExpedientes(datos.incidencias||[]) +
      htmlDetalleAreas(datos.incidencias||[], totArea) +
      htmlEtapasCierre(datos.etapasCierre, datos.sinIncidencias);
  });
}

// ════════════════════════════════════
// HELPERS
// ════════════════════════════════════
function parsearAreas(texto) {
  const r = {};
  Object.keys(AREAS_CFG).forEach(n => {
    const rx = new RegExp(`${n.replace('í','[íi]')}\\s*:\\s*(\\d+)`,'i');
    const m  = (texto||'').match(rx);
    if (m) r[n] = parseInt(m[1])||0;
  });
  return r;
}

function totalesPorArea(inc) {
  const t = {};
  Object.keys(AREAS_CFG).forEach(a => t[a]=0);
  inc.forEach(exp => {
    const map = parsearAreas(exp.areas);
    Object.entries(map).forEach(([a,n]) => { if(t[a]!==undefined) t[a]+=n; });
  });
  return t;
}

function colorArea(nombreArea) {
  const key = Object.keys(COLORES_AREA).find(k =>
    (nombreArea||'').toLowerCase().replace('í','i').includes(k.toLowerCase().replace('í','i'))
  );
  return COLORES_AREA[key] || { bg:'#f8fafc', border:'#e2e8f0', texto:'#475569' };
}

function tipoCSSClass(tipo) {
  if (!tipo) return 'tipo-normal';
  const t = tipo.toLowerCase();
  if (t==='normal')       return 'tipo-normal';
  if (t.includes('col'))  return 'tipo-col0';
  if (t.includes('renov'))return 'tipo-renovacion';
  if (t.includes('reestr'))return 'tipo-reestruc';
  if (t.includes('amplia'))return 'tipo-ampliacion';
  return 'tipo-normal';
}

function esJSON(obj) {
  return JSON.stringify(obj).replace(/'/g,"\\'").replace(/"/g,'&quot;');
}

// Parsear documentos igual que buildIncidenciasTableStyled
function parsearDocumentos(texto) {
  const raw = (texto == null ? '' : String(texto)).trim();
  if (!raw || raw === '—') return [];
  return raw.split('\n')
    .map(s => s.trim())
    .filter(s => s && /^[•\-·]/.test(s))
    .map(linea => {
      const parts = linea.replace(/^[•\-·]\s*/,'').split(' | ');
      return {
        area:        (parts[0]||'—').trim(),
        origen:      (parts[1]||'—').trim(),
        documento:   (parts[2]||'—').trim(),
        observacion: (parts[3]||'—').trim()
      };
    });
}

// ════════════════════════════════════
// HTML BUILDERS
// ════════════════════════════════════
function htmlSkeleton() {
  return `<div class="skeleton-wrap">
    <div class="skeleton-row"><div class="skeleton-box"></div><div class="skeleton-box"></div><div class="skeleton-box"></div></div>
    <div class="skeleton-bar w80"></div><div class="skeleton-bar w60"></div><div class="skeleton-bar w40"></div>
  </div>`;
}

function htmlHeader(chipTxt, label) {
  return `
  <div class="rep-header">
    <div class="rep-header-top">
      <div class="rep-logo-area">
        <div class="rep-logo-bg">
          <img src="https://cualli.mx/wp-content/uploads/2022/07/logo-cualli@3x.png" class="rep-logo-img" alt="Cualli"
               onerror="this.src='https://cualli.mx/wp-content/uploads/2022/07/cualli-bl@3x.png'">
        </div>
        <div>
          <div class="rep-header-titulo">EXPEDIENTES CUALLI / Cierre — Estatus de Integración</div>
          <div class="rep-header-sub">Contraloría Operativa · Sistema TESI · Control de Calidad</div>
        </div>
      </div>
      <div style="text-align:right;">
        <div class="rep-mes-chip">${chipTxt}</div>
        <div class="rep-anio">${label}</div>
      </div>
    </div>
  </div>`;
}

function htmlKPIs(total, completos, incidencias, pctC, pctI) {
  return `
  <div class="kpi-section">
    <div class="kpi-row">
      <div class="kpi-box total">
        <div class="kpi-icon-wrap"><img src="${ICONOS_KPI.total}" class="kpi-icon-img" alt="total"></div>
        <div><div class="kpi-num num-pop">${total}</div><div class="kpi-label">Expedientes Evaluados</div><div class="kpi-pct">Total del período</div></div>
      </div>
      <div class="kpi-box completos">
        <div class="kpi-icon-wrap"><img src="${ICONOS_KPI.completos}" class="kpi-icon-img" alt="completos"></div>
        <div><div class="kpi-num num-pop">${completos}</div><div class="kpi-label">Sin Incidencias</div><div class="kpi-pct">${pctC}% conformes</div></div>
      </div>
      <div class="kpi-box incidencias">
        <div class="kpi-icon-wrap"><img src="${ICONOS_KPI.incidencias}" class="kpi-icon-img" alt="incidencias"></div>
        <div><div class="kpi-num num-pop">${incidencias}</div><div class="kpi-label">Con Incidencias</div><div class="kpi-pct">${pctI}% con observaciones</div></div>
      </div>
    </div>
  </div>`;
}

// ── RUBROS — con detalle expandible al hacer clic ──
function htmlRubros(conteoPorTipo, incidencias, label) {
  if (!conteoPorTipo) return '';

  const tarjetas = Object.entries(RUBROS_CFG).map(([tipo, cfg]) => {
    const d = conteoPorTipo[tipo] || { total:0, conIncidencias:0 };
    const tieneInc = d.conIncidencias > 0;
    return `
      <div class="rubro-card ${cfg.cls}" id="rubro-card-${cfg.cls}" onclick="toggleRubro('${cfg.cls}')">
        <div class="rubro-nombre">${cfg.emoji} ${cfg.label}</div>
        <div class="rubro-total num-pop">${d.total}</div>
        <div class="rubro-sub">expediente${d.total!==1?'s':''}</div>
        <div class="${tieneInc?'rubro-inc-badge':'rubro-inc-badge cero'}">
          ${tieneInc?'⚠️':'✓'} ${d.conIncidencias} inc.
        </div>
        ${tieneInc ? '<span class="rubro-chevron">▾</span>' : ''}
      </div>`;
  }).join('');

  // Construir los detalles de cada rubro
  const detalles = Object.entries(RUBROS_CFG).map(([tipo, cfg]) => {
    const d = conteoPorTipo[tipo] || { total:0, conIncidencias:0 };
    if (!d.conIncidencias) return `<div class="rubro-detalle-wrap" id="rubro-detalle-${cfg.cls}"></div>`;

    // Filtrar expedientes de este tipo con incidencias
    const expsDelTipo = incidencias.filter(exp =>
      (exp.tipo||'').toLowerCase().replace('ó','o').replace('é','e') ===
      tipo.toLowerCase().replace('ó','o').replace('é','e')
    ).sort((a,b) => b.totalIncidencias - a.totalIncidencias);

    const filas = expsDelTipo.map((exp, idx) => {
      const bg = idx%2===0?'#ffffff':'#f8fafc';
      return `
        <tr style="background:${bg};" onclick='abrirDetalle(${esJSON(exp)})'>
          <td style="padding:11px 18px;border-bottom:1px solid #f1f5f9;">
            <span style="font-weight:600;font-size:12px;color:#1a202c;">${exp.id}</span>
          </td>
          <td style="padding:11px 18px;border-bottom:1px solid #f1f5f9;">
            <span style="font-size:12px;color:#718096;">${exp.fecha}</span>
          </td>
          <td style="padding:11px 18px;border-bottom:1px solid #f1f5f9;text-align:center;">
            <span class="inc-badge" style="border-color:#dc2626;color:#dc2626;font-size:12px;">${exp.totalIncidencias}</span>
          </td>
        </tr>`;
    }).join('');

    return `
      <div class="rubro-detalle-wrap" id="rubro-detalle-${cfg.cls}">
        <div class="rubro-detalle-inner">
          <div class="rubro-detalle-header">
            <span class="rubro-detalle-titulo">${cfg.emoji} ${cfg.label} — ${expsDelTipo.length} expediente${expsDelTipo.length!==1?'s':''} con incidencias</span>
          </div>
          <table class="tbl" style="border:none;border-radius:0;">
            <thead><tr>
              <th style="width:45%">ID Oportunidad</th>
              <th style="width:30%">Fecha de Firma</th>
              <th style="width:25%;text-align:center;">Incidencias</th>
            </tr></thead>
            <tbody>${filas}</tbody>
          </table>
        </div>
      </div>`;
  }).join('');

  return `
  <div class="rep-section">
    <div class="sec-titulo"><h2>Expedientes por Tipo</h2><p>Haz clic en un tipo para ver sus expedientes · ${label}</p></div>
    <div class="rubros-grid">${tarjetas}</div>
    <div id="rubros-detalles" style="margin-top:0;">${detalles}</div>
  </div>`;
}

// ── DISTRIBUCIÓN — con fila de total al final ──
function htmlDistribucion(totArea, totalIncs, label) {
  if (totalIncs === 0) {
    return `
    <div class="rep-section">
      <div class="sec-titulo"><h2>Distribución de Incidencias por Área</h2><p>Período: ${label}</p></div>
      <div style="background:linear-gradient(135deg,#f0fdf4,#dcfce7);border:1px solid #86efac;border-radius:12px;padding:26px 22px;display:flex;align-items:center;gap:20px;">
        <div style="width:54px;height:54px;background:linear-gradient(135deg,#059669,#10b981);border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
          <img src="https://cdn-icons-png.freepik.com/512/294/294432.png" width="28" height="28" alt="ok">
        </div>
        <div>
          <div style="font-size:19px;font-weight:800;color:#065f46;">Desempeño Excelente</div>
          <div style="font-size:14px;color:#047857;font-weight:500;margin-top:3px;">No se registraron incidencias en este período</div>
        </div>
      </div>
    </div>`;
  }

  const areasConInc = Object.entries(totArea).filter(([,v]) => v > 0);
  const filas = areasConInc.map(([nombre, valor], idx) => {
    const a   = AREAS_CFG[nombre];
    const pct = Math.round((valor/totalIncs)*100);
    const bg  = idx%2===0?'#ffffff':'#f8fafc';
    const bc  = '#f1f5f9';
    return `
      <tr style="background:${bg};">
        <td style="border-bottom:1px solid ${bc};">
          <div style="display:flex;align-items:center;gap:10px;">
            <img src="${a.icono}" width="34" height="34" alt="${nombre}" style="border-radius:4px;flex-shrink:0;">
            <span style="font-weight:700;font-size:13px;color:#1a202c;">${nombre}</span>
          </div>
        </td>
        <td style="border-bottom:1px solid ${bc};text-align:center;">
          <div style="width:46px;height:46px;background:linear-gradient(135deg,${a.colorClaro},${a.color});border-radius:50%;border:4px solid ${a.colorOscuro};display:inline-flex;align-items:center;justify-content:center;color:#fff;font-size:17px;font-weight:900;">
            ${valor}
          </div>
        </td>
        <td style="border-bottom:1px solid ${bc};">
          <div style="font-size:13px;color:#4a5568;font-weight:500;">${valor} incidencia${valor!==1?'s':''} · ${pct}% del total</div>
          <div class="prop-bar-bg" style="max-width:none;"><div class="prop-bar" style="background:${a.color};width:${pct}%"></div></div>
        </td>
        <td style="border-bottom:1px solid ${bc};text-align:right;width:60px;">
          <span style="font-size:12px;font-weight:700;color:#94a3b8;">${pct}%</span>
        </td>
      </tr>`;
  }).join('');

  return `
  <div class="rep-section">
    <div class="sec-titulo"><h2>Distribución de Incidencias por Área</h2><p>Período: ${label}</p></div>
    <table class="tbl">
      <thead><tr>
        <th style="width:28%">Área</th>
        <th style="width:12%;text-align:center;">Total</th>
        <th style="width:50%">Distribución</th>
        <th style="width:10%;text-align:right;">%</th>
      </tr></thead>
      <tbody>${filas}</tbody>
      <tfoot>
        <tr>
          <td><strong>Total general</strong></td>
          <td style="text-align:center;"><strong style="font-size:15px;color:#1a202c;">${totalIncs}</strong></td>
          <td><strong>incidencias registradas en el período</strong></td>
          <td style="text-align:right;"><strong>100%</strong></td>
        </tr>
      </tfoot>
    </table>
  </div>`;
}

// ── EXPEDIENTES ──
function htmlExpedientes(incidencias) {
  if (!incidencias.length) return '';
  const sorted  = [...incidencias].sort((a,b) => b.totalIncidencias-a.totalIncidencias);
  const mostrar = sorted.slice(0,15);
  const filas   = mostrar.map((exp, idx) => {
    const bg  = idx%2===0?'#ffffff':'#f8fafc';
    const bc  = idx===mostrar.length-1?'transparent':'#e2e8f0';
    const cls = tipoCSSClass(exp.tipo);
    return `
      <tr style="background:${bg};" onclick='abrirDetalle(${esJSON(exp)})'>
        <td style="border-bottom:1px solid ${bc};"><span style="font-weight:600;font-size:13px;">${exp.id}</span></td>
        <td style="border-bottom:1px solid ${bc};"><span style="color:#718096;font-size:13px;">${exp.fecha}</span></td>
        <td style="border-bottom:1px solid ${bc};"><span class="tipo-badge ${cls}">${exp.tipo||'—'}</span></td>
        <td style="border-bottom:1px solid ${bc};text-align:center;"><span class="inc-badge" style="border-color:#dc2626;color:#dc2626;">${exp.totalIncidencias}</span></td>
      </tr>`;
  }).join('');
  return `
  <div class="rep-section">
    <div class="tbl-controls">
      <div><div class="sec-titulo" style="text-align:left;margin-bottom:0;">
        <h2 style="font-size:20px;">Expedientes con Incidencias</h2>
        <p>Total: ${incidencias.length} expediente${incidencias.length!==1?'s':''}${mostrar.length<incidencias.length?' (top '+mostrar.length+')':''}</p>
      </div></div>
      <select class="sort-sel" onchange="reordenarExpedientes(this.value)">
        <option value="desc">↓ Más incidencias</option>
        <option value="asc">↑ Menos incidencias</option>
        <option value="fecha">📅 Por fecha</option>
      </select>
    </div>
    <table class="tbl">
      <thead><tr>
        <th style="width:35%">ID Oportunidad</th>
        <th style="width:18%">Fecha de Firma</th>
        <th style="width:27%">Tipo</th>
        <th style="width:20%;text-align:center;">Incidencias</th>
      </tr></thead>
      <tbody id="tbodyExp">${filas}</tbody>
    </table>
  </div>`;
}

// ── DETALLE POR ÁREA — documentos con parser correcto ──
function htmlDetalleAreas(incidencias, totArea) {
  let html = `
  <div class="rep-section">
    <div class="sec-titulo"><h2>Detalle por Área</h2><p>Documentos pendientes por departamento · haz clic para expandir</p></div>`;

  Object.entries(AREAS_CFG).forEach(([nombre, a]) => {
    const totalArea = totArea[nombre] || 0;

    // Recolectar todos los documentos de esta área usando el parser correcto
    const todosLosDocs = [];
    incidencias.forEach(exp => {
      const mapAreas = parsearAreas(exp.areas);
      if ((mapAreas[nombre]||0) > 0) {
        // Usar campo documentos si existe, sino parsear el texto crudo
        let docs = [];
        if (exp.documentos && exp.documentos.length > 0) {
          // Datos ya parseados por el GS
          docs = exp.documentos.filter(d => {
            const areaNorm = (d.area||'').toLowerCase().replace('í','i').replace('é','e');
            const buscar   = nombre.toLowerCase().replace('í','i').replace('é','e');
            return areaNorm.includes(buscar) || buscar.includes(areaNorm.split(' ')[0]);
          });
        } else if (exp.areas && typeof exp.areas === 'string') {
          // Parsear texto crudo de columna K si documentos no viene
          const raw = exp.detalleRaw || exp.areas;
          docs = parsearDocumentos(raw).filter(d => {
            const areaNorm = (d.area||'').toLowerCase().replace('í','i').replace('é','e');
            const buscar   = nombre.toLowerCase().replace('í','i').replace('é','e');
            return areaNorm.includes(buscar) || buscar.includes(areaNorm.split(' ')[0]);
          });
        }
        docs.forEach(d => todosLosDocs.push({ ...d, expId: exp.id }));
      }
    });

    if (totalArea > 0) {
      const c = colorArea(nombre);

      let contenidoDocs = '';
      if (todosLosDocs.length > 0) {
        const filasDocs = todosLosDocs.map((doc, i) => {
          const bg = i%2===0?'#f8fafc':'#ffffff';
          const ca = colorArea(doc.area);
          return `
            <tr style="background:${bg};">
              <td style="padding:13px 16px;border-bottom:1px solid #f1f5f9;text-align:center;">
                <div class="doc-num-circle">${i+1}</div>
              </td>
              <td style="padding:13px 16px;border-bottom:1px solid #f1f5f9;">
                <span class="area-doc-badge" style="background:${ca.bg};border-color:${ca.border};color:${ca.texto};">${doc.area}</span>
              </td>
              <td style="padding:13px 16px;border-bottom:1px solid #f1f5f9;">
                <div style="font-size:12px;font-weight:600;color:#334155;">${doc.origen}</div>
              </td>
              <td style="padding:13px 16px;border-bottom:1px solid #f1f5f9;">
                <div style="font-size:12px;font-weight:500;color:#475569;line-height:1.4;">${doc.documento}</div>
              </td>
              <td style="padding:13px 16px;border-bottom:1px solid #f1f5f9;">
                <div style="font-size:12px;color:#64748b;line-height:1.5;">
                  <span style="color:#3b82f6;font-weight:600;">•</span> ${doc.observacion}
                </div>
                <div style="font-size:10px;color:#cbd5e1;margin-top:3px;font-family:'Inter',sans-serif;">${doc.expId}</div>
              </td>
            </tr>`;
        }).join('');

        contenidoDocs = `
          <table class="docs-table">
            <thead><tr>
              <th style="width:40px;text-align:center;">#</th>
              <th style="width:12%;">Área</th>
              <th style="width:13%;">Origen</th>
              <th style="width:30%;">Documento / Campo</th>
              <th style="width:40%;">Comentario Mesa de Control</th>
            </tr></thead>
            <tbody>${filasDocs}</tbody>
          </table>`;
      } else {
        contenidoDocs = `<div style="padding:20px;font-size:12px;color:#94a3b8;text-align:center;font-style:italic;">Sin detalle de documentos disponible para este período</div>`;
      }

      html += `
        <div class="area-header-row" id="hdr-${nombre}" style="background:${a.colorBg};border-color:${a.colorBorder};" onclick="toggleArea('${nombre}')">
          <img src="${a.icono}" class="area-icon" alt="${nombre}">
          <div>
            <div class="area-nombre">${nombre}</div>
            <div class="area-subtext">${totalArea} incidencia${totalArea!==1?'s':''} · ${todosLosDocs.length} documento${todosLosDocs.length!==1?'s':''} pendiente${todosLosDocs.length!==1?'s':''}</div>
          </div>
          <div class="area-badge-num" style="background:linear-gradient(135deg,${a.colorClaro},${a.color});border:4px solid ${a.colorOscuro};">${totalArea}</div>
          <span class="area-chevron">▾</span>
        </div>
        <div class="area-detail-table" id="acordeon-${nombre}">
          <div style="background:#fff;border:1px solid ${a.colorBorder};border-top:none;border-radius:0 0 8px 8px;margin-bottom:8px;overflow:hidden;">
            <div style="background:${a.colorBg};padding:8px 18px;border-bottom:1px solid ${a.colorBorder};">
              <span style="font-size:10px;font-weight:700;color:#64748b;text-transform:uppercase;letter-spacing:1px;">Documentos pendientes de integración</span>
            </div>
            ${contenidoDocs}
          </div>
        </div>`;
    } else {
      html += `
        <div class="area-ok">
          <img src="${a.icono}" class="area-icon" alt="${nombre}">
          <div><div class="area-ok-nombre">${nombre}</div><div class="area-ok-sub">✓ Sin incidencias registradas</div></div>
        </div>`;
    }
  });

  html += `</div>`;
  return html;
}

// ── ETAPAS CIERRE ──
function htmlEtapasCierre(etapasCierre, totalCompletos) {
  if (!etapasCierre) return '';
  const e1  = etapasCierre['1a Revision']||0;
  const e2  = etapasCierre['2a Revision']||0;
  const ef  = etapasCierre['Final']||0;
  const tot = e1+e2+ef;
  const pct = n => tot>0?Math.round((n/tot)*100):0;
  return `
  <div class="rep-section">
    <div class="sec-titulo"><h2>Cierre de Incidencias por Etapa</h2><p>De ${totalCompletos} expediente${totalCompletos!==1?'s':''} completo${totalCompletos!==1?'s':''} · ${tot} con etapa registrada</p></div>
    <div class="cierre-grid">
      <div class="cierre-card e1"><div class="cierre-icon">🥇</div><div><div class="cierre-num num-pop">${e1}</div><div class="cierre-label">Cerró en 1ª Revisión</div><div class="cierre-sub">${pct(e1)}% de los cierres</div></div></div>
      <div class="cierre-card e2"><div class="cierre-icon">🥈</div><div><div class="cierre-num num-pop">${e2}</div><div class="cierre-label">Cerró en 2ª Revisión</div><div class="cierre-sub">${pct(e2)}% de los cierres</div></div></div>
      <div class="cierre-card ef"><div class="cierre-icon">🏁</div><div><div class="cierre-num num-pop">${ef}</div><div class="cierre-label">Cerró en Revisión Final</div><div class="cierre-sub">${pct(ef)}% de los cierres</div></div></div>
    </div>
  </div>`;
}

