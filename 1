  datos.incidencias.forEach(exp => {
    const m = exp._areasMap || parsearAreas(exp.areas);
    if (m[nombre]) { map[nombre] = (map[nombre]||0) + m[nombre]; tot += m[nombre]; }
  });
  const exp = {
    id:               `Área: ${nombre}`,
    fecha:            getPeriodoLabel(),
    totalIncidencias: tot,
    _areasMap:        map
  };
  abrirDetalle(exp);
}

function cerrarPanel() {
  document.getElementById('overlay').classList.remove('open');
  document.getElementById('slidePanel').classList.remove('open');
}

// Helper: serializar objeto para onclick inline
function esJSON(obj) {
  return JSON.stringify(obj).replace(/'/g,"\\'").replace(/"/g,'&quot;');
}
