// Rubros expandibles
function toggleRubro(cls) {
  const detalle = document.getElementById(`rubro-detalle-${cls}`);
  if (!detalle || !detalle.innerHTML.trim()) return; // sin incidencias, no hace nada

  const card     = document.getElementById(`rubro-card-${cls}`);
  const estaOpen = detalle.classList.contains('open');

  // Cerrar todos
  document.querySelectorAll('.rubro-detalle-wrap').forEach(d => d.classList.remove('open'));
  document.querySelectorAll('.rubro-card').forEach(c => c.classList.remove('activo'));

  if (!estaOpen) {
    detalle.classList.add('open');
    card && card.classList.add('activo');
    rubroAbierto = cls;
    // Scroll suave al detalle
    setTimeout(() => detalle.scrollIntoView({ behavior:'smooth', block:'nearest' }), 50);
  } else {
    rubroAbierto = null;
  }
}

// Acordeón áreas
function toggleArea(nombre) {
  const el  = document.getElementById(`acordeon-${nombre}`);
  const hdr = document.getElementById(`hdr-${nombre}`);
  if (!el) return;
  const abierto = el.classList.contains('open');
  document.querySelectorAll('.area-detail-table').forEach(d => d.classList.remove('open'));
  document.querySelectorAll('.area-header-row').forEach(h => h.classList.remove('open'));
  if (!abierto) {
    el.classList.add('open');
    hdr && hdr.classList.add('open');
    setTimeout(() => el.scrollIntoView({ behavior:'smooth', block:'nearest' }), 50);
  }
}

// Reordenar expedientes
function reordenarExpedientes(orden) {
  if (!datosMostrados) return;
  let exps = [...(datosMostrados.incidencias||[])];
  if (orden==='desc')      exps.sort((a,b) => b.totalIncidencias-a.totalIncidencias);
  else if (orden==='asc')  exps.sort((a,b) => a.totalIncidencias-b.totalIncidencias);
  else                     exps.sort((a,b) => a.fecha.localeCompare(b.fecha));
  const mostrar = exps.slice(0,15);
  const tbody   = document.getElementById('tbodyExp');
  if (!tbody) return;
  tbody.innerHTML = mostrar.map((exp,idx) => {
    const bg  = idx%2===0?'#ffffff':'#f8fafc';
    const bc  = idx===mostrar.length-1?'transparent':'#e2e8f0';
    const cls = tipoCSSClass(exp.tipo);
    return `<tr style="background:${bg};" onclick='abrirDetalle(${esJSON(exp)})'>
      <td style="border-bottom:1px solid ${bc};"><span style="font-weight:600;font-size:13px;">${exp.id}</span></td>
      <td style="border-bottom:1px solid ${bc};"><span style="color:#718096;font-size:13px;">${exp.fecha}</span></td>
      <td style="border-bottom:1px solid ${bc};"><span class="tipo-badge ${cls}">${exp.tipo||'—'}</span></td>
      <td style="border-bottom:1px solid ${bc};text-align:center;"><span class="inc-badge" style="border-color:#dc2626;color:#dc2626;">${exp.totalIncidencias}</span></td>
    </tr>`;
  }).join('');
}

// Panel detalle expediente
function abrirDetalle(exp) {
  document.getElementById('spId').textContent    = exp.id;
  document.getElementById('spFecha').textContent = `Fecha de firma: ${exp.fecha}`;
  document.getElementById('spTotal').textContent = exp.totalIncidencias;
  const map    = parsearAreas(exp.areas);
  const conInc = Object.entries(map).filter(([,n]) => n>0);
  document.getElementById('spAreas').textContent = conInc.length;
  document.getElementById('spAreasList').innerHTML = conInc
    .sort((a,b) => b[1]-a[1])
    .map(([nombre,n]) => {
      const a   = AREAS_CFG[nombre];
      const pct = Math.round((n/exp.totalIncidencias)*100);
      return `
        <div class="sp-area-row">
          <div class="sp-area-left">
            <div class="sp-area-dot" style="background:${a?.color||'#888'}"></div>
            <div><div class="sp-area-name">${nombre}</div><div class="sp-area-pct">${pct}% del total</div></div>
          </div>
          <div class="sp-area-num" style="color:${a?.color||'#888'}">${n}</div>
        </div>`;
    }).join('');
  document.getElementById('overlay').classList.add('open');
  document.getElementById('slidePanel').classList.add('open');
}

function cerrarPanel() {
  document.getElementById('overlay').classList.remove('open');
  document.getElementById('slidePanel').classList.remove('open');
}
