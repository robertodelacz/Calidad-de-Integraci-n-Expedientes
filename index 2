function htmlDetalleAreas(incidencias, totArea) {
  const areasOrdenadas = Object.entries(AREAS_CFG).sort(([nA],[nB]) => (totArea[nB]||0)-(totArea[nA]||0));
  let html = `<div class="rep-section"><div class="sec-titulo"><h2>Detalle por Área</h2><p>Documentos pendientes de integración</p></div>`;

  areasOrdenadas.forEach(([nombre, a]) => {
    const totalArea = totArea[nombre]||0;
    const todosLosDocs = [];
    incidencias.forEach(exp => {
      const mapAreas = parsearAreas(exp.areas);
      if ((mapAreas[nombre]||0) === 0) return;
      if (exp.documentos && exp.documentos.length > 0) {
        exp.documentos.filter(d => {
          const aN = (d.area||'').toLowerCase().replace('í','i'); const bN = nombre.toLowerCase().replace('í','i');
          return aN.includes(bN) || bN.includes(aN.split(' ')[0]);
        }).forEach(d => todosLosDocs.push({...d, expId:exp.id}));
      } else {
        parsearDocumentosHTML(exp.areas||'').filter(d => {
          const aN = (d.area||'').toLowerCase().replace('í','i'); const bN = nombre.toLowerCase().replace('í','i');
          return aN.includes(bN) || bN.includes(aN.split(' ')[0]);
        }).forEach(d => todosLosDocs.push({...d, expId:exp.id}));
      }
    });

    if (totalArea > 0) {
      const contenido = todosLosDocs.length > 0
        ? `<table class="docs-table"><thead><tr><th style="width:55%;">Documento pendiente</th><th>Comentario</th></tr></thead><tbody>
          ${todosLosDocs.map((doc,i) => {
            const bg = i%2===0?'#f8fafc':'#fff';
            const docLimpio = (doc.documento||'').replace(/^\*+\s*/,'').replace(/^\d+\.\s*/,'').replace(/^\*+\s*/,'').replace(/\s*\/.*$/,'').trim()||'—';
            const obs = doc.observacion||doc.comentario||'—';
            return `<tr style="background:${bg};"><td style="padding:13px 18px;border-bottom:1px solid #f1f5f9;width:55%;"><div style="display:flex;align-items:flex-start;gap:10px;"><div class="doc-num">${i+1}</div><div style="font-size:12px;font-weight:700;color:#1a202c;line-height:1.4;padding-top:3px;">${docLimpio}</div></div></td><td style="padding:13px 18px;border-bottom:1px solid #f1f5f9;"><div style="font-size:12px;color:#64748b;line-height:1.5;"><span style="color:#3b82f6;font-weight:700;">•</span> ${obs}</div><div style="font-size:10px;color:#cbd5e1;margin-top:3px;font-family:'Inter',sans-serif;">${doc.expId}</div></td></tr>`;
          }).join('')}
          </tbody></table>`
        : `<div style="padding:20px;font-size:12px;color:#94a3b8;text-align:center;font-style:italic;">Sin detalle de documentos disponible</div>`;

      html += `
        <div class="area-header-row" id="hdr-${nombre}" style="background:${a.colorBg};border-color:${a.colorBorder};" onclick="toggleArea('${nombre}')">
          <img src="${a.icono}" class="area-icon" alt="${nombre}">
          <div><div class="area-nombre">${nombre}</div><div class="area-subtext">${totalArea} incidencia${totalArea!==1?'s':''} · ${todosLosDocs.length} documento${todosLosDocs.length!==1?'s':''} pendiente${todosLosDocs.length!==1?'s':''}</div></div>
          <div class="area-badge-num" style="background:linear-gradient(135deg,${a.colorClaro},${a.color});border:4px solid ${a.colorOscuro};">${totalArea}</div>
          <span class="area-chevron">▾</span>
        </div>
        <div class="area-detail-table" id="acordeon-${nombre}">
          <div style="background:#fff;border:1px solid ${a.colorBorder};border-top:none;border-radius:0 0 8px 8px;margin-bottom:8px;overflow:hidden;">
            <div style="background:${a.colorBg};padding:8px 18px;border-bottom:1px solid ${a.colorBorder};"><span style="font-size:10px;font-weight:700;color:#64748b;text-transform:uppercase;letter-spacing:1px;">Documentos pendientes de integración</span></div>
            ${contenido}
          </div>
        </div>`;
    } else {
      html += `<div class="area-ok"><img src="${a.icono}" class="area-icon" alt="${nombre}"><div><div class="area-ok-nombre">${nombre}</div><div class="area-ok-sub">✓ Sin incidencias registradas</div></div></div>`;
    }
  });
  return html + `</div>`;
}

// ════════════════════════════════════════════════════════════
// ✦ initCharts — SISTEMA REDISEÑADO
//
// CAUSAS DEL BUG de etiquetas dobles:
//   1) Chart.register(ChartDataLabels) se llamaba DENTRO de initCharts(),
//      ejecutándose múltiples veces. El plugin quedaba registrado N veces
//      y se dibujaba N veces por cada render. SOLUCIÓN: el registro está
//      al inicio del script, fuera de cualquier función.
//   2) Se creaba gradiente con ctxK pero se reutilizaba para otro canvas.
//      SOLUCIÓN: cada canvas crea su propio contexto local.
//
// MEJORAS DE DISEÑO:
//   — maintainAspectRatio: false en los 3 charts (respeta height CSS)
//   — responsive: true (se redimensiona con la ventana)
//   — Etiquetas con fondo blanco semitransparente, sin solapamiento
//   — Sombra en segmentos con plugin custom
//   — Animación de entrada por arco (animateRotate)
//   — Pie usa 'pie' real con padding para separación visual
// ════════════════════════════════════════════════════════════
function initCharts(datos) {

  // Plugin de sombra — se define localmente (no se registra globalmente para evitar duplicados)
  const shadowPlugin = {
    id: 'shadowPlugin',
    beforeDraw(chart) {
      const ctx = chart.ctx;
      ctx.save();
      ctx.shadowColor   = 'rgba(0,0,0,0.15)';
      ctx.shadowBlur    = 18;
      ctx.shadowOffsetX = 0;
      ctx.shadowOffsetY = 6;
    },
    afterDraw(chart) {
      chart.ctx.restore();
    }
  };

  // ── Configuración de etiquetas EXTERNA (fuera del arco) ──
  // ✦ 'display: auto' deja que el plugin decida cuándo omitir si hay solapamiento
  const externalLabels = {
    display(ctx) {
      const total = ctx.dataset.data.reduce((s, v) => s + v, 0);
      const pct   = total > 0 ? Math.round((ctx.dataset.data[ctx.dataIndex] / total) * 100) : 0;
      return pct >= 5; // Ocultar si el segmento es < 5% (evita solapamiento en segmentos chicos)
    },
    formatter(value, ctx) {
      const total = ctx.dataset.data.reduce((s, v) => s + v, 0);
      const pct   = total > 0 ? Math.round((value / total) * 100) : 0;
      return pct + '%';
    },
    color:       '#fff',
    font:        { family:'IBM Plex Sans', weight:'800', size:12 },
    anchor:      'center',
    align:       'center',
    // Fondo con rounding para legibilidad sobre cualquier color
    backgroundColor(ctx) {
      const colors = ctx.dataset.backgroundColor;
      return Array.isArray(colors) ? colors[ctx.dataIndex] : colors;
    },
    borderRadius: 4,
    padding:      { top:3, bottom:3, left:6, right:6 },
    // ✦ textShadowBlur da legibilidad sin necesitar borde blanco
    textShadowBlur:  4,
    textShadowColor: 'rgba(0,0,0,0.4)',
    clip:            false,
  };

  // ══════════════════════════════════════
  // CHART 1 — ESTATUS GLOBAL (Doughnut)
  // ══════════════════════════════════════
  const elKPI = document.getElementById('chartKPI');
  if (elKPI) {
    const ctx  = elKPI.getContext('2d');
    const gOK  = ctx.createLinearGradient(0, 0, 0, 300);
    gOK.addColorStop(0, '#34d399');
    gOK.addColorStop(1, '#059669');
    const gINC = ctx.createLinearGradient(0, 0, 0, 300);
    gINC.addColorStop(0, '#f87171');
    gINC.addColorStop(1, '#dc2626');

    window.charts.chartKPI = new Chart(ctx, {
      type: 'doughnut',
      plugins: [shadowPlugin],
      data: {
        labels: ['Sin Incidencias', 'Con Incidencias'],
        datasets: [{
          data:            [window._kpiData.completos, window._kpiData.incidencias],
          backgroundColor: [gOK, gINC],
          borderWidth:     4,
          borderColor:     '#fff',
          hoverBorderWidth: 0,
          borderRadius:    8,
          spacing:         4,
          hoverOffset:     16,
        }]
      },
      options: {
        responsive:          true,
        maintainAspectRatio: false,
        cutout:              '72%',
        animation: {
          animateRotate: true,
          animateScale:  false,
          duration:      900,
          easing:        'easeOutQuart',
        },
        plugins: {
          legend: {
            position: 'bottom',
            labels: {
              boxWidth:  10,
              boxHeight: 10,
              borderRadius: 3,
              useBorderRadius: true,
              font:    { size:10, weight:'700', family:'IBM Plex Sans' },
              color:   '#64748b',
              padding: 16,
            }
          },
          // ✦ Sin etiquetas internas en la dona (el total va en el centro con HTML)
          datalabels: { display: false },
          tooltip: {
            callbacks: {
              label(ctx) {
                const total = ctx.dataset.data.reduce((s,v)=>s+v,0);
                const pct   = total > 0 ? Math.round((ctx.parsed/total)*100) : 0;
                return ` ${ctx.label}: ${ctx.raw} (${pct}%)`;
              }
            }
          }
        }
      }
    });
  }

  // ══════════════════════════════════════
  // CHART 2 — DISTRIBUCIÓN POR TIPO (Pie)
  // ══════════════════════════════════════
  const elRubros = document.getElementById('chartRubros');
  if (elRubros) {
    const ctx = elRubros.getContext('2d');
    const COLORES_RUBROS = ['#FDB913','#64748b','#06b6d4','#f97316','#a855f7'];
    const nombresRubros  = Object.keys(RUBROS_CFG);
    const valoresRubros  = nombresRubros.map(t => datos.conteoPorTipo?.[t]?.total || 0);
    const totalRubros    = valoresRubros.reduce((s,v) => s+v, 0);

    window.charts.chartRubros = new Chart(ctx, {
      type: 'pie',
      plugins: [shadowPlugin],
      data: {
        labels: nombresRubros.map((t,i) => `${RUBROS_CFG[t].emoji} ${RUBROS_CFG[t].label}`),
        datasets: [{
          data:            valoresRubros,
          backgroundColor: COLORES_RUBROS,
          borderWidth:     4,
          borderColor:     '#fff',
          hoverBorderWidth: 0,
          hoverOffset:     20,
        }]
      },
      options: {
        responsive:          true,
        maintainAspectRatio: false,
        layout: {
          // ✦ Padding extra para que las etiquetas no queden cortadas
          padding: { top:20, bottom:20, left:20, right:20 }
        },
        animation: {
          animateRotate: true,
          animateScale:  true,
          duration:      1000,
          easing:        'easeOutElastic',
        },
        plugins: {
          legend: {
            position: 'right',
            labels: {
              boxWidth:  10,
              boxHeight: 10,
              borderRadius: 3,
              useBorderRadius: true,
              font:    { size:10, weight:'700', family:'IBM Plex Sans' },
              color:   '#64748b',
              padding: 10,
              // ✦ Filtrar segmentos en cero de la leyenda
              filter: (item) => valoresRubros[item.index] > 0,
            }
          },
          datalabels: {
            ...externalLabels,
            // ✦ Para el pie, mostrar sólo si el segmento tiene datos
            display(ctx) {
              const total = ctx.dataset.data.reduce((s,v)=>s+v,0);
              const pct   = total > 0 ? Math.round((ctx.dataset.data[ctx.dataIndex]/total)*100) : 0;
              return pct >= 5;
            },
          },
          tooltip: {
            callbacks: {
              label(ctx) {
                const pct = totalRubros > 0 ? Math.round((ctx.parsed/totalRubros)*100) : 0;
                return ` ${ctx.label}: ${ctx.raw} exp. (${pct}%)`;
              }
            }
          }
        }
      }
    });
  }

  // ══════════════════════════════════════
  // CHART 3 — EFICIENCIA DE CIERRE (Doughnut)
  // ══════════════════════════════════════
  const elCierre = document.getElementById('chartCierre');
  if (elCierre) {
    const ctx = elCierre.getContext('2d');
    const COLORES_CIERRE = ['#3b82f6','#f59e0b','#10b981'];

    window.charts.chartCierre = new Chart(ctx, {
      type: 'doughnut',
      plugins: [shadowPlugin],
      data: {
        labels: ['1ª Revisión', '2ª Revisión', 'Revisión Final'],
        datasets: [{
          data:            window._cierreData || [0,0,0],
          backgroundColor: COLORES_CIERRE,
          borderWidth:     4,
          borderColor:     '#fff',
          hoverBorderWidth: 0,
          borderRadius:    8,
          spacing:         4,
          hoverOffset:     16,
        }]
      },
      options: {
        responsive:          true,
        maintainAspectRatio: false,
        cutout:              '65%',
        animation: {
          animateRotate: true,
          animateScale:  false,
          duration:      900,
          easing:        'easeOutQuart',
        },
        layout: { padding: 10 },
        plugins: {
          legend: {
            position: 'bottom',
            labels: {
              boxWidth:  10,
              boxHeight: 10,
              borderRadius: 3,
              useBorderRadius: true,
              font:    { size:10, weight:'700', family:'IBM Plex Sans' },
              color:   '#64748b',
              padding: 14,
            }
          },
          datalabels: {
            ...externalLabels,
            display(ctx) {
              const total = ctx.dataset.data.reduce((s,v)=>s+v,0);
              const pct   = total > 0 ? Math.round((ctx.dataset.data[ctx.dataIndex]/total)*100) : 0;
              return pct >= 5;
            },
          },
          tooltip: {
            callbacks: {
              label(ctx) {
                const total = ctx.dataset.data.reduce((s,v)=>s+v,0);
                const pct   = total > 0 ? Math.round((ctx.parsed/total)*100) : 0;
                return ` ${ctx.label}: ${ctx.raw} (${pct}%)`;
              }
            }
          }
        }
      }
    });
  }
}

